{
  "icon_theme": "Zed (Default)",
  "theme": "GitHub Dark Default",
  "buffer_font_family": "Zed Mono",
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": true,
    "liga": true,
    "dlig": true,
  },
  "buffer_line_height": {
    "custom": 1.5,
  },
  "soft_wrap": "editor_width",
  "preferred_line_length": 100,
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "show_whitespaces": "selection",
  "show_wrap_guides": true,
  "cursor_blink": true,
  "file_types": {
    "Brewfile": ["Ruby"],
    "*.sh": ["Shell Script"],
    "*.bash": ["Shell Script"],
    "*.zsh": ["Shell Script"],
    ".env": ["Shell Script"],
    ".zshrc": ["Shell Script"],
    ".zprofile": ["Shell Script"],
  },
  "base_keymap": "VSCode",
  "show_call_status_icon": false,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "confirm_quit": false,
  "restore_on_startup": "last_workspace",
  "extend_comment_on_newline": true,
  "use_autoclose": true,
  "show_completion_documentation": true,
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/node_modules",
    "**/.next",
    "**/tmp",
    "**/dist",
    "**/build",
    "**/coverage",
    "**/.cache",
    "**/.idea",
    "**/*.log",
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/*.pyc",
  ],
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_other_hints": true,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600,
    },
  },
  "terminal": {
    "font_size": 14,
    "font_family": "Zed Mono",
    "line_height": {
      "custom": 1.4,
    },
    "shell": {
      "program": "zsh",
    },
    "copy_on_select": true,
    "dock": "bottom",
    "default_width": 640,
    "default_height": 320,
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "disable_ai": true,
  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic",
            "autoImportCompletions": true,
          },
        },
      },
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true,
          "importModuleSpecifierPreference": "shortest",
          "quotePreference": "single",
        },
      },
    },
  },
  "languages": {
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
      "format_on_save": "on",
      "language_servers": ["pyright", "ruff"],
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
    "Bash": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "language_servers": ["bash-language-server"],
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-"],
        },
      },
    },
    "JavaScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "HTML": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": "prettier",
    },
    "CSS": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": "prettier",
    },
  },
}
